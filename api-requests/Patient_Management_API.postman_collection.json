          "raw": "http://localhost:4000/patients/123e4567-e89b-12d3-a456-426614174000",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["patients", "123e4567-e89b-12d3-a456-426614174000"]
        },
        "description": "Retrieve a specific patient by ID"
      }
    },
    {
      "name": "Create New Patient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Patient\",\n  \"email\": \"test.patient@example.com\",\n  \"address\": \"456 Oak Avenue, New York, NY 10001\",\n  \"dateOfBirth\": \"1990-05-15\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/patients/add-patient",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["patients", "add-patient"]
        },
        "description": "Create a new patient record"
      }
    },
